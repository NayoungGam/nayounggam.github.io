*, ::after, ::before { box-sizing: border-box; }

* { margin: 0px; padding: 0px; }

html { -webkit-font-smoothing: antialiased; text-size-adjust: none; font-sy=
nthesis-weight: none; }

button { appearance: button; background: none; border-radius: 0px; border-s=
tyle: none; color: inherit; cursor: pointer; font: inherit; letter-spacing:=
 inherit; text-transform: none; vertical-align: middle; }

a { text-decoration: none; }

:where([aria-role=3D"button"]), a, button, input, label, select, textarea {=
 touch-action: manipulation; }

ol, ul { list-style: none; }

b, strong { font-weight: bolder; }

blockquote, q { quotes: none; }

blockquote::after, blockquote::before, q::after, q::before { content: none;=
 }

pre { white-space: pre-wrap; }

hr { border-style: solid; border-width: 1px 0px 0px; color: inherit; height=
: 1px; overflow: visible; }

table { border-collapse: collapse; border-color: currentcolor; border-spaci=
ng: 0px; text-indent: 0px; }

audio, img, svg, video { vertical-align: middle; }

img, svg { flex-grow: 0; flex-shrink: 0; }

iframe { border-style: none; }

input, optgroup, select, textarea { appearance: none; border-radius: 0px; b=
order-style: none; box-shadow: none; color: inherit; filter: none; font: in=
herit; letter-spacing: inherit; outline-offset: 0px; outline-width: 2px; }

input::-webkit-input-placeholder { color: darkgray; opacity: 1; }

input::placeholder { color: darkgray; opacity: 1; }

textarea { resize: vertical; }

:root { --minimumApplicationHeight: 100%; }

body, html { height: 100%; }

#root { min-height: var(--minimumApplicationHeight); }

@media only screen and (min-width: 450px) {
  body { overflow: overlay; }
}

