@-webkit-keyframes shimmer {=20
  100% { transform: translateX(100%); }
}

@keyframes shimmer {=20
  100% { transform: translateX(100%); }
}

@-webkit-keyframes growIn {=20
  0% { transform: scale(0); }
  100% { transform: scale(1); }
}

@keyframes growIn {=20
  0% { transform: scale(0); }
  100% { transform: scale(1); }
}

@-webkit-keyframes growIn75 {=20
  0% { transform: scale(0.75); }
  100% { transform: scale(1); }
}

@keyframes growIn75 {=20
  0% { transform: scale(0.75); }
  100% { transform: scale(1); }
}

@-webkit-keyframes fadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes fadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@-webkit-keyframes shimmerMove {=20
  0% { transform: translateX(-150%); }
  100% { transform: translateX(150%); }
}

@keyframes shimmerMove {=20
  0% { transform: translateX(-150%); }
  100% { transform: translateX(150%); }
}

