Content-Type: text/css
Content-Transfer-Encoding: quoted-printable
Content-Location: cid:css-cc6023c2-c6e3-4f05-9063-fdb917f23a04@mhtml.blink

@charset "utf-8";

* { -webkit-tap-highlight-color: transparent; -webkit-font-smoothing: antia=
liased; }

body, html { margin: 0px; padding: 0px; font-family: -apple-system, system-=
ui, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, "Helvetica Neue=
", Arial, sans-serif; overflow: hidden; height: 100%; width: 100%; backgrou=
nd-color: transparent; }

fieldset { margin: 0px; padding: 15px 20px; border-width: medium; border-st=
yle: none; border-color: currentcolor; border-image: initial; }

button:focus, input:focus, select:focus, textarea:focus { outline: 0px; }

:focus { border-width: medium; border-style: none; border-color: currentcol=
or; border-image: initial; outline: 0px; }

textarea { border-width: medium; border-style: none; border-color: currentc=
olor; border-image: initial; overflow: auto; outline: 0px; box-shadow: none=
; resize: none; }

.no-selection { user-select: none; }

@-webkit-keyframes pop {=20
  0% { transform: scale(0); }
  70% { transform: scale(1.8); }
  80% { transform: scale(0.6); }
  100% { transform: scale(1); }
}

@keyframes pop {=20
  0% { transform: scale(0); }
  70% { transform: scale(1.8); }
  80% { transform: scale(0.6); }
  100% { transform: scale(1); }
}
